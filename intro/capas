struct FuncAggregateMonster
{
	LPCHARACTER m_ch;
	int m_range;
	int m_limit;
	int m_chance;
	int m_count;
	bool m_useParams;
	// Construtor para versão básica (compatibilidade: quest/GM)
	FuncAggregateMonster(LPCHARACTER ch)
		: m_ch(ch), m_range(5000), m_limit(999999), m_chance(50), m_count(0), m_useParams(false)
	{}
#if defined(__BRAVERY_CAPE_RENEWAL__)
	// Construtor para versão com parâmetros (item capa)
	FuncAggregateMonster(LPCHARACTER ch, int range, int limit, int chance)
		: m_ch(ch), m_range(range), m_limit(limit), m_chance(chance), m_count(0), m_useParams(true)
	{}
#endif
	void operator()(LPENTITY ent)
	{
		if (!ent->IsType(ENTITY_CHARACTER))
			return;
		LPCHARACTER ch = (LPCHARACTER)ent;
		if (ch->IsPC() || !ch->IsMonster() || ch->GetVictim())
			return;
		if (ch->GetMapIndex() != m_ch->GetMapIndex())
			return;
		if (DISTANCE_APPROX(ch->GetX() - m_ch->GetX(), ch->GetY() - m_ch->GetY()) >= m_range)
			return;
		if (m_useParams)
		{
			if (m_count >= m_limit)
				return;
			if (m_chance < 100 && number(1, 100) > m_chance)
				return;
		}
		else
		{
			if (number(1, 100) > 50)
				return;
		}
		if (ch->CanBeginFight())
		{
			ch->BeginFight(m_ch);
			++m_count;
		}
	}
};
Nota: Usei 999999 como “sem limite” para não depender de <limits>. Se tiveres #include <limits>, podes usar m_limit(std::numeric_limits<int>::max()) no primeiro construtor.
