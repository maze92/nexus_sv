4.1 Substituir a estrutura FuncAggregateMonster
Remover a estrutura inteira desde struct FuncAggregateMonster até ao }; que a fecha (incluindo o comentário com caracteres especiais).
Inserir no mesmo sítio (entre o }; de FuncForgetMyAttacker e o struct FuncAttractRanger) o seguinte.
Aqui está a versão com VID (Lei dos Ponteiros): guarda m_dwUserVID e resolve com CHARACTER_MANAGER::instance().Find(m_dwUserVID) no operator().
struct FuncAggregateMonster
{
	DWORD m_dwUserVID;  // Lei 1: VID em vez de ponteiro bruto
	int m_range;
	int m_limit;
	int m_chance;
	int m_count;
	bool m_useParams;
	// Construtor para versão básica (compatibilidade: quest/GM)
	FuncAggregateMonster(LPCHARACTER ch)
		: m_dwUserVID(ch ? ch->GetVID() : 0), m_range(5000), m_limit(999999), m_chance(50), m_count(0), m_useParams(false)
	{}
#if defined(__BRAVERY_CAPE_RENEWAL__)
	// Construtor para versão com parâmetros (item capa)
	FuncAggregateMonster(LPCHARACTER ch, int range, int limit, int chance)
		: m_dwUserVID(ch ? ch->GetVID() : 0), m_range(range), m_limit(limit), m_chance(chance), m_count(0), m_useParams(true)
	{}
#endif
	void operator()(LPENTITY ent)
	{
		if (!ent->IsType(ENTITY_CHARACTER))
			return;
		// Lei 1: resolver VID na hora de usar; null-check silencioso
		LPCHARACTER chUser = CHARACTER_MANAGER::instance().Find(m_dwUserVID);
		if (!chUser)
			return;
		LPCHARACTER ch = (LPCHARACTER)ent;
		if (ch->IsPC() || !ch->IsMonster() || ch->GetVictim())
			return;
		if (ch->GetMapIndex() != chUser->GetMapIndex())
			return;
		if (DISTANCE_APPROX(ch->GetX() - chUser->GetX(), ch->GetY() - chUser->GetY()) >= m_range)
			return;
		if (m_useParams)
		{
			if (m_count >= m_limit)
				return;
			if (m_chance < 100 && number(1, 100) > m_chance)
				return;
		}
		else
		{
			if (number(1, 100) > 50)
				return;
		}
		if (ch->CanBeginFight())
		{
			ch->BeginFight(chUser);
			++m_count;
		}
	}
};
