7. Vai até o final do ficheiro Input.cpp e adiciona as lógicas do Raw Input:

C++

#if defined(ENABLE_RAW_INPUT)
// ==========================================
// RAW INPUT - TECLADO
// ==========================================
void CInputKeyboard::SetUseRawInput(bool enable) { ms_bUseRawInput = enable; }
bool CInputKeyboard::IsUsingRawInput() { return ms_bUseRawInput; }

bool CInputKeyboard::RegisterRawInputKeyboard(HWND hWnd)
{
	RAWINPUTDEVICE rid;
	rid.usUsagePage = 0x01; // generic desktop controls
	rid.usUsage = 0x06;     // keyboard
	rid.dwFlags = RIDEV_INPUTSINK;
	rid.hwndTarget = hWnd;
	return RegisterRawInputDevices(&rid, 1, sizeof(rid)) == TRUE;
}

static int __RawInputMakeDik(const RAWKEYBOARD& rk)
{
	UINT make = rk.MakeCode & 0xFF;
	UINT flags = rk.Flags;
	if ((flags & RI_KEY_E0) && (make == 0x2A || make == 0x36)) return -1;
	if ((flags & RI_KEY_E1) && make == 0x1D) return 0xC5; // DIK_PAUSE
	int dik = (int)make;
	if (flags & RI_KEY_E0) dik |= 0x80;
	return dik;
}

void CInputKeyboard::ProcessRawInputKeyboard(const RAWINPUT* raw)
{
	if (!ms_bUseRawInput || raw->header.dwType != RIM_TYPEKEYBOARD) return;

	const RAWKEYBOARD& rk = raw->data.keyboard;
	int dik = __RawInputMakeDik(rk);
	if (dik < 0 || dik >= 256) return;

	const bool isBreak = (rk.Flags & RI_KEY_BREAK) != 0;
	if (isBreak)
	{
		ms_diks[dik] = 0; // Desliga o bit
		if (IsPressed(dik)) KeyUp(dik);
	}
	else
	{
		ms_diks[dik] = 0x80; // Liga o bit (formato DirectInput)
		if (!IsPressed(dik)) KeyDown(dik);
	}
}

// ==========================================
// RAW INPUT - RATO
// ==========================================
void CInputMouse::SetUseRawInput(bool enable) { ms_bUseRawInput = enable; }
bool CInputMouse::IsUsingRawInput() { return ms_bUseRawInput; }

bool CInputMouse::RegisterRawInputMouse(HWND hWnd)
{
	RAWINPUTDEVICE rid;
	rid.usUsagePage = 0x01; // generic desktop controls
	rid.usUsage = 0x02;     // mouse
	rid.dwFlags = RIDEV_INPUTSINK; 
	rid.hwndTarget = hWnd;
	return RegisterRawInputDevices(&rid, 1, sizeof(rid)) == TRUE;
}

void CInputMouse::ProcessRawInputMouse(const RAWINPUT* raw)
{
	if (!ms_bUseRawInput || raw->header.dwType != RIM_TYPEMOUSE) return;

	const RAWMOUSE& rm = raw->data.mouse;

	// Movimento Relativo (Câmera)
	if ((rm.usFlags & MOUSE_MOVE_ABSOLUTE) == 0)
	{
		m_lX += rm.lLastX;
		m_lY += rm.lLastY;
	}

	// Scroll do Rato
	if (rm.usButtonFlags & RI_MOUSE_WHEEL)
	{
		m_lZ += (short)rm.usButtonData;
	}

	// Botão Esquerdo
	if (rm.usButtonFlags & RI_MOUSE_LEFT_BUTTON_DOWN)
		m_bLeftButtonDown = true;
	if (rm.usButtonFlags & RI_MOUSE_LEFT_BUTTON_UP)
		m_bLeftButtonDown = false;

	// Botão Direito
	if (rm.usButtonFlags & RI_MOUSE_RIGHT_BUTTON_DOWN)
		m_bRightButtonDown = true;
	if (rm.usButtonFlags & RI_MOUSE_RIGHT_BUTTON_UP)
		m_bRightButtonDown = false;

	// Botão do Meio
	if (rm.usButtonFlags & RI_MOUSE_MIDDLE_BUTTON_DOWN)
		m_bMiddleButtonDown = true;
	if (rm.usButtonFlags & RI_MOUSE_MIDDLE_BUTTON_UP)
		m_bMiddleButtonDown = false;
}
#endif
