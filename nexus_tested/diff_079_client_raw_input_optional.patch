4. Atualizar o PythonApplicationProcedure.cpp
No seu WM_INPUT, agora precisamos distribuir os dados tanto para o teclado quanto para o mouse. O código ficará muito mais limpo se você fizer a leitura do buffer aqui e só repassar o ponteiro raw para a classe correta:

C++

#if defined(ENABLE_RAW_INPUT)
		case WM_INPUT:
		{
			UINT dwSize = 0;
			GetRawInputData((HRAWINPUT)lParam, RID_INPUT, NULL, &dwSize, sizeof(RAWINPUTHEADER));
			
			if (dwSize > 0)
			{
				std::vector<BYTE> buffer(dwSize);
				if (GetRawInputData((HRAWINPUT)lParam, RID_INPUT, buffer.data(), &dwSize, sizeof(RAWINPUTHEADER)) == dwSize)
				{
					const RAWINPUT* raw = (const RAWINPUT*)buffer.data();
					
					if (raw->header.dwType == RIM_TYPEKEYBOARD)
						CInputKeyboard::ProcessRawInput(raw); // Ajuste a função do teclado para receber 'const RAWINPUT* raw' em vez de lParam
					else if (raw->header.dwType == RIM_TYPEMOUSE)
						CInputMouse::ProcessRawInputMouse(raw);
				}
			}
			return DefWindowProc(hWnd, uiMsg, wParam, lParam);
		}
#endif
