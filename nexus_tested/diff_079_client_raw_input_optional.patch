2. Atualizar o Input.cpp
Agora vamos implementar a lógica. O segredo aqui é que o Metin2/EterLib precisa do movimento relativo (para girar a câmera) e do estado dos botões.

Adicione as variáveis e funções no Input.cpp (perto das implementações do CInputMouse):

C++

#if defined(ENABLE_RAW_INPUT)
bool CInputMouse::ms_bUseRawInput = false;

void CInputMouse::SetUseRawInput(bool enable)
{
	ms_bUseRawInput = enable;
}

bool CInputMouse::IsUsingRawInput()
{
	return ms_bUseRawInput;
}

bool CInputMouse::RegisterRawInputMouse(HWND hWnd)
{
	RAWINPUTDEVICE rid;
	rid.usUsagePage = 0x01; // generic desktop controls
	rid.usUsage = 0x02;     // mouse
	rid.dwFlags = RIDEV_INPUTSINK; 
	rid.hwndTarget = hWnd;

	return RegisterRawInputDevices(&rid, 1, sizeof(rid)) == TRUE;
}

