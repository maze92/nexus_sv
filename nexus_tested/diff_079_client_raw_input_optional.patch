LRESULT CPythonApplication::WindowProcedure(HWND hWnd, UINT uiMsg, WPARAM wParam, LPARAM lParam)
{
	// ...

	switch (uiMsg)
	{
		// ...

		case WM_CHAR:
		{
			// ...
			return CPythonIME::Instance().WMChar(hWnd, uiMsg, wParam, lParam);
		}

#if defined(ENABLE_RAW_INPUT)
		case WM_INPUT:
		{
			UINT dwSize = 0;
			GetRawInputData((HRAWINPUT)lParam, RID_INPUT, NULL, &dwSize, sizeof(RAWINPUTHEADER));

			if (dwSize > 0)
			{
				std::vector<BYTE> buffer(dwSize);
				if (GetRawInputData((HRAWINPUT)lParam, RID_INPUT, buffer.data(), &dwSize, sizeof(RAWINPUTHEADER)) == dwSize)
				{
					const RAWINPUT* raw = (const RAWINPUT*)buffer.data();
					if (raw->header.dwType == RIM_TYPEKEYBOARD)
						CInputKeyboard::ProcessRawInputKeyboard(raw);
				}
			}
			return 0;
		}
#endif

		case WM_KEYDOWN:
		{
			// IME mantém-se via WM_KEYDOWN/WM_CHAR (não uso NOLEGACY no registo)
			OnIMEKeyDown(LOWORD(wParam));
		}
		break;

		// ...
