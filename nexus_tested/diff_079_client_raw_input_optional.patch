#include "StdAfx.h"
#include "Input.h"

#if !defined(ENABLE_RAW_INPUT)
LPDIRECTINPUT8 CInputDevice::ms_lpDI = NULL;
LPDIRECTINPUTDEVICE8 CInputKeyboard::ms_lpKeyboard = NULL;
#endif

#if defined(ENABLE_RAW_INPUT)
bool CInputKeyboard::ms_bUseRawInput = false;
#endif

bool CInputKeyboard::ms_bPressedKey[256];
char CInputKeyboard::ms_diks[256];

CInputDevice::CInputDevice()
{
}

CInputDevice::~CInputDevice()
{
#if !defined(ENABLE_RAW_INPUT)
	SAFE_RELEASE(ms_lpDI);
#endif
}

HRESULT CInputDevice::CreateDevice(HWND /*hWnd*/)
{
#if !defined(ENABLE_RAW_INPUT)
	if (ms_lpDI)
	{
		ms_lpDI->AddRef();
		return S_OK;
	}

	HRESULT hr;

	// Create a DInput object
	if (FAILED(hr = DirectInput8Create(GetModuleHandle(NULL), DIRECTINPUT_VERSION,
		IID_IDirectInput8, (VOID**)&ms_lpDI, NULL)))
		return hr;

	return S_OK;
#else
	// Raw Input build: DirectInput disabled
	return S_OK;
#endif
}

CInputKeyboard::CInputKeyboard()
{
	ResetKeyboard();
}

CInputKeyboard::~CInputKeyboard()
{
#if !defined(ENABLE_RAW_INPUT)
	if (ms_lpKeyboard)
		ms_lpKeyboard->Unacquire();

	SAFE_RELEASE(ms_lpKeyboard);
#endif
}

void CInputKeyboard::ResetKeyboard()
{
	memset(ms_diks, 0, sizeof(ms_diks));
	memset(ms_bPressedKey, 0, sizeof(ms_bPressedKey));
}

bool CInputKeyboard::InitializeKeyboard(HWND hWnd)
{
	NANOBEGIN

#if !defined(ENABLE_RAW_INPUT)
		if (ms_lpKeyboard)
			return true;

	if (FAILED(CreateDevice(hWnd)))
		return false;

	HRESULT hr;

	// Obtain an interface to the system keyboard device.
	if (FAILED(hr = ms_lpDI->CreateDevice(GUID_SysKeyboard, &ms_lpKeyboard, NULL)))
		return false;

	if (FAILED(hr = ms_lpKeyboard->SetDataFormat(&c_dfDIKeyboard)))
		return false;

	// Alt + F4    - [levites]
	//DWORD dwCoopFlags = DISCL_FOREGROUND | DISCL_EXCLUSIVE;
	//DWORD dwCoopFlags = DISCL_NONEXCLUSIVE | DISCL_BACKGROUND;
	DWORD dwCoopFlags = DISCL_FOREGROUND | DISCL_NONEXCLUSIVE;

	if (FAILED(hr = ms_lpKeyboard->SetCooperativeLevel(hWnd, dwCoopFlags)))
		return false;

	ms_lpKeyboard->Acquire();
#endif

	NANOEND
		return true;
}

void CInputKeyboard::UpdateKeyboard()
{
#if defined(ENABLE_RAW_INPUT)
	if (ms_bUseRawInput)
		return;
#endif

#if !defined(ENABLE_RAW_INPUT)
	if (!ms_lpKeyboard)
		return;

	HRESULT hr;

	hr = ms_lpKeyboard->GetDeviceState(sizeof(ms_diks), &ms_diks);

	if (FAILED(hr))
	{
		hr = ms_lpKeyboard->Acquire();

		//  ø̼ Ȱȭ Ǿ ־ Է   .
		//if (hr == DIERR_OTHERAPPHASPRIO || hr == DIERR_NOTACQUIRED);
		return;
	}

	for (int i = 0; i < 256; ++i)
	{
		if (ms_diks[i] & 0x80)
		{
			if (!IsPressed(i))
				KeyDown(i);
		}
		else if (IsPressed(i))
			KeyUp(i);
	}
#endif
}

void CInputKeyboard::KeyDown(int iIndex)
{
	ms_bPressedKey[iIndex] = true;
	OnKeyDown(iIndex);
}

void CInputKeyboard::KeyUp(int iIndex)
{
	ms_bPressedKey[iIndex] = false;
	OnKeyUp(iIndex);
}

bool CInputKeyboard::IsPressed(int iIndex)
{
	return ms_bPressedKey[iIndex];
}

#if defined(ENABLE_RAW_INPUT)
// ==========================================
// RAW INPUT - TECLADO
// ==========================================
void CInputKeyboard::SetUseRawInput(bool enable) { ms_bUseRawInput = enable; }
bool CInputKeyboard::IsUsingRawInput() { return ms_bUseRawInput; }

bool CInputKeyboard::RegisterRawInputKeyboard(HWND hWnd)
{
	RAWINPUTDEVICE rid;
	rid.usUsagePage = 0x01; // generic desktop controls
	rid.usUsage = 0x06;     // keyboard
	// Mantém legacy (WM_KEYDOWN/WM_CHAR) para IME/texto.
	// Se quiseres suprimir duplicação de mensagens, usa RIDEV_NOLEGACY|RIDEV_NOHOTKEYS.
	rid.dwFlags = 0;
	rid.hwndTarget = hWnd;
	return RegisterRawInputDevices(&rid, 1, sizeof(rid)) == TRUE;
}

static int __RawInputMakeDik(const RAWKEYBOARD& rk)
{
	UINT make = rk.MakeCode & 0xFF;
	UINT flags = rk.Flags;

	// Filtra o "fake E0" dos shifts
	if ((flags & RI_KEY_E0) && (make == 0x2A || make == 0x36)) return -1;

	// Pause (E1 1D 45...) mapeia para DIK_PAUSE (0xC5)
	if ((flags & RI_KEY_E1) && make == 0x1D) return 0xC5;

	int dik = (int)make;
	if (flags & RI_KEY_E0) dik |= 0x80; // convenção DI
	return dik;
}

void CInputKeyboard::ProcessRawInputKeyboard(const RAWINPUT* raw)
{
	if (!ms_bUseRawInput || !raw || raw->header.dwType != RIM_TYPEKEYBOARD) return;

	const RAWKEYBOARD& rk = raw->data.keyboard;
	int dik = __RawInputMakeDik(rk);
	if (dik < 0 || dik >= 256) return;

	const bool wasPressed = IsPressed(dik);
	const bool isBreak = (rk.Flags & RI_KEY_BREAK) != 0;

	if (isBreak)
	{
		ms_diks[dik] = 0; // formato DirectInput
		if (wasPressed) KeyUp(dik);
	}
	else
	{
		ms_diks[dik] = (char)0x80; // formato DirectInput
		if (!wasPressed) KeyDown(dik);
	}
}
#endif
